# .env.example - REDACTED Swarm Environment Configuration
# Copy to .env for local use. Never commit real secrets!
# For testing/documentation only — replace placeholders with your values.

# ───────────────────────────────────────────────
# LLM / Model Providers (required for most agents)
# ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROK_API_KEY=gsk_...
# Optional: if using other providers via plugins
# DEEPSEEK_API_KEY=...
# QWEN_API_KEY=...  (local Ollama usually doesn't need this)

# ───────────────────────────────────────────────
# Automation & Integrations
# ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
CLAWNX_API_KEY=your-clawnx-key-here          # For X/Twitter automation (ClawnX node)
1CLICK_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # NEAR Intents 1Click auth (required for bridging)

# ───────────────────────────────────────────────
# Crypto / Wallet / On-Chain Execution
# ───────────────────────────────────────────────
# Phantom MCP / Solana signing (use with extreme care - never expose in production!)
ETHEREUM_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Or use devnet/testnet for safety:
# SOLANA_RPC_URL=https://api.devnet.solana.com

WALLET_MNEMONIC="apple banana cherry dog echo fox golf hotel india juliet kilo lima"  # 12-word BIP39 - EXAMPLE ONLY - DO NOT USE
WALLET_PASSPHRASE=example-only-do-not-use

# Example token mint (used in liquidity/engineering agents)
PROJECT_TOKEN_MINT=9mtKd1o8Ht7F1daumKgs5D8EdVyopWBfYQwNmMojpump

# Optional: additional chains / RPCs if expanding beyond Solana/EVM
# BASE_RPC_URL=https://mainnet.base.org
# NEAR_RPC_URL=https://rpc.mainnet.near.org

# ───────────────────────────────────────────────
# Docker / Runtime / Ollama (from our earlier compose setup)
# ───────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
DEFAULT_MODEL=qwen2.5:latest   # or llama3.1:8b, deepseek-r1, etc.
POSTGRES_URL=postgres://user:pass@postgres:5432/swarm

# Optional: if adding a simple dashboard or API exposure
PORT=3000

# ───────────────────────────────────────────────
# Misc / GitHub (if automating repo interactions or CI)
# ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_000000000000000000000000000000000000   # Personal Access Token (classic or fine-grained)
